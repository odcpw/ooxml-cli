OPENAI_API_KEY=
OOXML_FLUE_MODEL=openai/gpt-5.5
OOXML_BIN=ooxml
OOXML_WEB_DATA_DIR=../.flue-ooxml-web-data
APP_BASE_URL=http://localhost:3583

# Auth
# Default local magic-link delivery writes JSONL links under OOXML_WEB_DATA_DIR/auth.
EMAIL_TRANSPORT=dev
EMAIL_FROM=no-reply@ooxml-workbench.local
OOXML_MAGIC_LINK_LOG=
OOXML_AUTH_ALLOWED_EMAIL_DOMAINS=
OOXML_AUTH_DEV_BYPASS=0
OOXML_AUTH_DEV_SESSIONS=0
OOXML_DEV_AUTH_EMAIL=oliver@local.test

# Microsoft OAuth
MICROSOFT_OAUTH_TENANT=common
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=
OOXML_MICROSOFT_REQUIRE_EDOV=1

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Optional email transports when EMAIL_TRANSPORT is resend/postmark/mailgun.
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_BASE_URL=

# Local limits
OOXML_UPLOAD_MAX_FILES=10
OOXML_UPLOAD_MAX_BYTES=52428800
OOXML_UPLOAD_RATE_LIMIT_PER_HOUR=60
OOXML_RENDER_RATE_LIMIT_PER_HOUR=120
OOXML_AGENT_RATE_LIMIT_PER_MINUTE=20
