{
  "name": "ooxml-flue-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "flue dev --target node --port 3583",
    "build": "flue build --target node",
    "start": "node dist/server.mjs",
    "typecheck": "tsc --noEmit",
    "smoke:agent": "node scripts/smoke-agent-edit.mjs",
    "smoke:auth": "node scripts/smoke-auth-isolation.mjs",
    "smoke:auth-abuse": "node scripts/smoke-auth-abuse.mjs",
    "smoke:nonpptx": "node scripts/smoke-nonpptx.mjs"
  },
  "dependencies": {
    "@flue/runtime": "1.0.0-beta.1",
    "@flue/sdk": "1.0.0-beta.1",
    "hono": "^4.8.3",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.1",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "ws": "8.21.0"
  }
}
